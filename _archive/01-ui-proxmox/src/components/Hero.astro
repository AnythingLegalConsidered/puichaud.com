---
// Hero: readable by everyone (recruiters, jury), before the console below.
import { PROFILE } from '../data/profile';
---

<header class="hero">
  <p class="status-line">
    <span class="dot running" aria-hidden="true"></span>
    homelab <span id="hero-uptime" style="color:var(--color-success)">99.2%</span>
    · 2 nodes · 12 LXC sous Terraform · 0 port exposé
  </p>
  <h1>{PROFILE.name} <span class="accent">—</span> SysOps</h1>
  <p class="sub">
    Alternant AdminSys chez EQUANS · BAC+3 SYSOPS (EPSI Nantes) · cap Master Infra &amp; Cloud 09/2026.
    Ce portfolio est le miroir de ma vraie infrastructure : les métriques ci-dessous proviennent
    d'un export régulier de mon homelab. Explorez la console.
  </p>
  <nav class="cta" aria-label="Actions principales">
    <a class="px-btn primary" href={PROFILE.cvHref} download>Télécharger le CV</a>
    <a class="px-btn" href={`https://${PROFILE.github}`} target="_blank" rel="noopener">GitHub ↗</a>
  </nav>
</header>
