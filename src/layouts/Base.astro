---
const {
  title = 'Ianis Puichaud — Administrateur Systèmes & Réseaux · IaC',
  description = 'Support N2 et admin systèmes chez Equans (Active Directory, sécurité du poste), homelab Proxmox en IaC. Recherche alternance Master Infra & Cloud — Nantes, 2026.',
  canonicalPath = '/',
  image = '/og-image.png',
  schema = null,
  robots = null,
} = Astro.props;

const origin = 'https://puichaud.com';
const canonical = new URL(canonicalPath, origin).toString();
const ogImage = new URL(image, origin).toString();
// Polices auto-hébergées (perf + pas d'appel tiers vers Google — conformité CNIL)
import '@fontsource/cinzel/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import inter400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import inter600 from '@fontsource/inter/files/inter-latin-600-normal.woff2?url';
import cinzel700 from '@fontsource/cinzel/files/cinzel-latin-700-normal.woff2?url';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {robots && <meta name="robots" content={robots} />}
  <meta name="theme-color" content="#3A2F24" />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preload" href={inter400} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter600} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={cinzel700} as="font" type="font/woff2" crossorigin />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Ianis Puichaud" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={`Aperçu — ${title}`} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={`Aperçu — ${title}`} />

  <!-- JSON-LD Person -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Ianis Puichaud',
    jobTitle: 'Administrateur Systèmes & Réseaux (alternance)',
    worksFor: { '@type': 'Organization', name: 'Equans' },
    alumniOf: { '@type': 'CollegeOrUniversity', name: 'EPSI Nantes' },
    address: { '@type': 'PostalAddress', addressLocality: 'Nantes', addressCountry: 'FR' },
    url: origin,
    sameAs: [
      'https://github.com/AnythingLegalConsidered',
      'https://www.linkedin.com/in/ianispuichaud',
    ],
    knowsAbout: ['Active Directory', 'Proxmox', 'Terraform', 'Ansible', 'Infrastructure as Code', 'DevOps'],
  })} />
  {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}

</head>
<body>
  <slot />
  <script is:inline src="/scripts/site.js" defer></script>
</body>
</html>
