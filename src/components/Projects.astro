---
import { projects } from '../data/projects.js';

const [dataCommune, hexalith, homelab, automation] = projects;
---

<section id="projets">
  <div class="wrap">
    <div class="sec-head"><h2>Études de cas</h2><div class="rule"></div></div>
    <p class="sec-intro">
      Pas une liste de technologies : le problème, les décisions, les preuves et
      les limites de ce que j’ai réellement construit.
    </p>

    <article class="project-lead">
      <div class="project-copy">
        <div class="project-index">{dataCommune.number} · produit exploité</div>
        <div class="project-title-row">
          <h3>{dataCommune.name}</h3>
          <span class="project-status"><i aria-hidden="true"></i>{dataCommune.status}</span>
        </div>
        <p class="project-summary">{dataCommune.summary}</p>
        <dl class="proof-grid">
          {dataCommune.facts.map((fact) => (
            <div><dt>{fact.value}</dt><dd>{fact.label}</dd></div>
          ))}
        </dl>
        <p class="project-outcome">{dataCommune.outcome}</p>
        <div class="project-actions">
          <a class="case-link" href={`/projets/${dataCommune.slug}/`}>Lire l’étude de cas <span aria-hidden="true">→</span></a>
          {dataCommune.external && <a class="external-link" href={dataCommune.external.href} target="_blank" rel="noopener">Voir le produit ↗</a>}
        </div>
      </div>
      <a class="project-visual" href={`/projets/${dataCommune.slug}/`} aria-label={`Interface publique · capture réelle — découvrir l’étude de cas ${dataCommune.name}`}>
        <img src={dataCommune.image} alt={dataCommune.imageAlt} width="1280" height="577" loading="lazy" decoding="async" />
        <span>Interface publique · capture réelle</span>
      </a>
    </article>

    <div class="project-pair">
      {[hexalith, homelab].map((project) => (
        <article class="project-brief">
          <div class="project-index">{project.number} · {project.meta}</div>
          <h3>{project.name}</h3>
          <p>{project.summary}</p>
          <dl class="proof-grid compact">
            {project.facts.map((fact) => (
              <div><dt>{fact.value}</dt><dd>{fact.label}</dd></div>
            ))}
          </dl>
          <p class="project-limit">{project.limits[0]}</p>
          <a class="case-link" href={`/projets/${project.slug}/`}>Voir les preuves <span aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>

    <article class="project-note">
      <div>
        <div class="project-index">{automation.number} · contexte confidentiel</div>
        <h3>{automation.name}</h3>
        <p>{automation.summary}</p>
      </div>
      <dl class="proof-grid compact">
        {automation.facts.map((fact) => (
          <div><dt>{fact.value}</dt><dd>{fact.label}</dd></div>
        ))}
      </dl>
      <a class="case-link" href={`/projets/${automation.slug}/`}>Lire le périmètre public <span aria-hidden="true">→</span></a>
    </article>
  </div>
</section>

<style>
  #projets {
    background: var(--parchment);
    border-top: 1px solid var(--stone);
    border-bottom: 1px solid var(--stone);
  }

  .project-lead {
    display: grid;
    grid-template-columns: 1.02fr .98fr;
    border: 2px solid var(--bronze-dark);
    background: var(--surface);
    box-shadow: 0 18px 48px rgba(42, 31, 20, .1);
  }

  .project-copy { padding: 34px; }

  .project-index {
    font: 500 10.5px/1.4 var(--mono);
    color: var(--bronze-dark);
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  .project-title-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 8px;
  }

  h3 {
    font: 700 28px/1.15 var(--serif);
    color: var(--ink);
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font: 500 11px/1 var(--mono);
    color: var(--green);
  }

  .project-status i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
  }

  .project-summary {
    margin-top: 16px;
    color: var(--ink);
    font-size: 15px;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin: 24px 0;
    border-block: 1px solid var(--stone);
  }

  .proof-grid div { padding: 14px 12px 13px 0; }
  .proof-grid div + div { padding-left: 12px; border-left: 1px solid var(--stone); }
  .proof-grid dt { font: 700 20px/1 var(--serif); color: var(--ink); }
  .proof-grid dd {
    margin-top: 6px;
    font: 500 9.5px/1.4 var(--mono);
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--ink-muted);
  }

  .project-outcome,
  .project-limit { color: var(--ink-muted); font-size: 13.5px; }

  .project-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 24px;
  }

  .case-link,
  .external-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-size: 13px;
    font-weight: 650;
  }

  .case-link span { margin-left: 8px; transition: transform .15s ease; }
  .case-link:hover span { transform: translateX(4px); }
  .external-link { color: var(--ink-muted); font-weight: 500; }

  .project-visual {
    position: relative;
    overflow: hidden;
    min-height: 100%;
    background: var(--column);
    border-left: 1px solid var(--bronze-dark);
  }

  .project-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(.78) contrast(.98);
    transition: transform .45s cubic-bezier(.22, .61, .36, 1), filter .2s;
  }

  .project-visual:hover img { transform: scale(1.025); filter: saturate(1); }
  .project-visual span {
    position: absolute;
    left: 16px;
    bottom: 14px;
    padding: 6px 9px;
    background: rgba(30, 26, 21, .88);
    color: var(--marble);
    font: 500 9.5px/1 var(--mono);
    letter-spacing: .05em;
    text-transform: uppercase;
  }

  .project-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 18px;
  }

  .project-brief,
  .project-note {
    border: 1px solid var(--stone);
    border-top: 3px solid var(--bronze);
    background: var(--marble);
    padding: 28px;
  }

  .project-brief h3,
  .project-note h3 { margin-top: 7px; font-size: 21px; }
  .project-brief > p,
  .project-note p { margin-top: 12px; font-size: 14px; color: var(--ink-muted); }
  .project-brief .case-link { margin-top: 13px; }

  .proof-grid.compact { margin: 20px 0 12px; }
  .proof-grid.compact dt { font-size: 17px; }
  .proof-grid.compact dd { font-size: 8.5px; }

  .project-note {
    display: grid;
    grid-template-columns: 1.2fr 1fr auto;
    gap: 24px;
    align-items: center;
    margin-top: 18px;
    border-top-color: var(--stone);
  }

  .project-note .proof-grid { margin: 0; }

  @media (max-width: 760px) {
    .project-lead { grid-template-columns: 1fr; }
    .project-copy { padding: 25px 22px; }
    .project-index { font-size: 11px; }
    .project-visual { min-height: 190px; border-left: 0; border-top: 1px solid var(--bronze-dark); }
    .project-pair { grid-template-columns: 1fr; }
    .project-brief,
    .project-note { padding: 24px 22px; }
    .project-note { grid-template-columns: 1fr; gap: 8px; }
    .project-note .proof-grid { margin: 14px 0 0; }
  }

  @media (max-width: 440px) {
    .project-title-row { align-items: flex-start; flex-direction: column; gap: 7px; }
    .project-copy,
    .project-brief,
    .project-note { padding-inline: 18px; }
    .proof-grid div { padding-inline: 6px; }
    .proof-grid div + div { padding-left: 6px; }
    .proof-grid div:first-child { padding-left: 0; }
    .proof-grid dt { font-size: 18px; }
    .proof-grid dd { font-size: 10.5px; line-height: 1.35; }
    .project-actions { align-items: flex-start; flex-direction: column; gap: 2px; }
  }
</style>
