---
import { projects } from '../data/projects.js';

const [dataCommune, hexalith, homelab, automation] = projects;
---

<section id="projets">
  <div class="wrap">
    <div class="sec-head"><h2>Études de cas</h2><div class="rule"></div></div>
    <p class="sec-intro">
      Pas une liste de technologies : le problème, les décisions, les preuves et
      les limites de ce que j’ai réellement construit.
    </p>

    <!-- 01 · DataCommune — capture à gauche, copy à droite -->
    <article class="case-row" style={`--accent: ${dataCommune.accent}`}>
      <a class="case-shot" href={`/projets/${dataCommune.slug}/`} aria-label={`${dataCommune.imageAlt} — lire l’étude de cas ${dataCommune.name}`}>
        <span class="pv-chrome" aria-hidden="true"><i></i><i></i><i></i><b>{dataCommune.domain}</b></span>
        <img src={dataCommune.image} alt={dataCommune.imageAlt} width="1280" height="577" loading="lazy" decoding="async" />
      </a>
      <div class="case-copy">
        <div class="case-index">{dataCommune.number}</div>
        <div class="case-title-row">
          <h3>{dataCommune.name}</h3>
          <span class="case-status"><i aria-hidden="true"></i>{dataCommune.status}</span>
        </div>
        <p class="case-summary">{dataCommune.summary}</p>
        <dl class="case-facts">
          {dataCommune.facts.map((fact) => (
            <div><dt>{fact.value}</dt><dd>{fact.label}</dd></div>
          ))}
        </dl>
        <div class="case-actions">
          <a class="case-link" href={`/projets/${dataCommune.slug}/`}>Lire l’étude de cas <span aria-hidden="true">→</span></a>
          {dataCommune.external && <a class="external-link" href={dataCommune.external.href} target="_blank" rel="noopener">Voir le produit ↗</a>}
        </div>
      </div>
    </article>

    <!-- 02 · Hexalith — copy à gauche, capture à droite -->
    <article class="case-row rev" style={`--accent: ${hexalith.accent}`}>
      <div class="case-copy">
        <div class="case-index">{hexalith.number}</div>
        <div class="case-title-row">
          <h3>{hexalith.name}</h3>
        </div>
        <p class="case-summary">{hexalith.summary}</p>
        <dl class="case-facts">
          {hexalith.facts.map((fact) => (
            <div><dt>{fact.value}</dt><dd>{fact.label}</dd></div>
          ))}
        </dl>
        <div class="case-actions">
          <a class="case-link" href={`/projets/${hexalith.slug}/`}>Voir les preuves <span aria-hidden="true">→</span></a>
        </div>
      </div>
      <a class="case-shot" href={`/projets/${hexalith.slug}/`} aria-label={`${hexalith.imageAlt} — voir les preuves ${hexalith.name}`}>
        <span class="pv-chrome" aria-hidden="true"><i></i><i></i><i></i><b>{hexalith.domain}</b></span>
        <img src={hexalith.image} alt={hexalith.imageAlt} width="1280" height="577" loading="lazy" decoding="async" />
      </a>
    </article>

    <!-- 03 · Homelab — topologie terminal à gauche (repo privé, pas de capture), copy à droite -->
    <article class="case-row" style={`--accent: ${homelab.accent}`}>
      <div class="case-topo" aria-hidden="true">
        <div class="case-topo-bar"><span>homelab.topology</span><em>IaC · repo privé</em></div>
        <div class="case-topo-body">
          <div><b>git</b> → Terraform + Ansible → Proxmox</div>
          <div>13 LXC en IaC</div>
          <div>PBS + restic — <b>3-2-1 restaurée-testée</b></div>
        </div>
      </div>
      <div class="case-copy">
        <div class="case-index">{homelab.number}</div>
        <div class="case-title-row">
          <h3>{homelab.name}</h3>
        </div>
        <p class="case-summary">{homelab.summary}</p>
        <dl class="case-facts">
          {homelab.facts.map((fact) => (
            <div><dt>{fact.value}</dt><dd>{fact.label}</dd></div>
          ))}
        </dl>
        <div class="case-actions">
          <a class="case-link" href={`/projets/${homelab.slug}/`}>Voir les preuves <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </article>

    <!-- 04 · Automatisation AD — mention discrète, une ligne -->
    <div class="case-note" style={`--accent: ${automation.accent}`}>
      <span class="case-index">{automation.number}</span>
      <strong>{automation.name}</strong>
      <p>{automation.summary}</p>
      <a class="case-link" href={`/projets/${automation.slug}/`}>Lire le périmètre public <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>

<style>
  #projets {
    background: var(--parchment);
    border-top: 1px solid var(--stone);
    border-bottom: 1px solid var(--stone);
  }

  /* rangées éditoriales alternées, séparées par le filet standard */
  .case-row {
    display: grid;
    grid-template-columns: 55% 1fr;
    gap: 44px;
    align-items: center;
    padding-block: 46px;
  }
  .case-row:first-of-type { padding-top: 4px; }
  .case-row + .case-row { border-top: 1px solid var(--stone); }
  .case-row.rev { grid-template-columns: 1fr 55%; }

  .case-index {
    font: 500 12px/1 var(--mono); color: var(--accent);
    letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 10px;
  }

  .case-title-row { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  h3 { font: 700 clamp(24px, 3.4vw, 30px)/1.12 var(--serif); color: var(--ink); }

  .case-status {
    display: inline-flex; align-items: center; gap: 6px;
    font: 500 11px/1 var(--mono); color: var(--green);
  }
  .case-status i { width: 7px; height: 7px; border-radius: 50%; background: var(--green); }

  .case-summary { margin-top: 12px; color: var(--ink); font-size: 15px; }

  /* chiffres en ligne — aucune grille, aucun filet vertical */
  .case-facts {
    display: flex; flex-wrap: wrap; align-items: baseline;
    gap: 6px 4px; margin: 20px 0 22px;
  }
  .case-facts div { display: inline-flex; align-items: baseline; gap: 8px; }
  .case-facts div:not(:last-child)::after {
    content: '·'; color: var(--stone); margin: 0 10px 0 14px;
  }
  .case-facts dt { font: 700 20px/1 var(--serif); color: var(--accent); }
  .case-facts dd {
    font: 500 10px/1.3 var(--mono);
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--ink-muted);
  }

  .case-actions { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .case-link,
  .external-link {
    display: inline-flex; align-items: center; gap: 8px;
    min-height: 40px; font-size: 13px; font-weight: 650;
  }
  .case-link span { transition: transform .15s ease; }
  .case-link:hover span { transform: translateX(4px); }
  .external-link { color: var(--ink-muted); font-weight: 500; }

  /* capture — barre chrome : signale que c'est un site externe */
  .case-shot {
    display: block;
    border: 1px solid var(--stone); border-radius: var(--r-panel);
    overflow: hidden; background: var(--column);
    box-shadow: 0 14px 40px rgba(19, 26, 21, .12);
  }
  .case-shot img { display: block; width: 100%; height: auto; }
  .pv-chrome {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 12px; background: var(--column);
  }
  .pv-chrome i { width: 8px; height: 8px; border-radius: 50%; background: rgba(250, 246, 240, .25); }
  .pv-chrome b { margin-left: 6px; font: 500 10px/1 var(--mono); color: var(--marble-dark); }

  /* mini-topologie terminal (esprit .infra-panel) */
  .case-topo {
    border: 1px solid #ffffff1f; border-radius: var(--r-panel);
    background: #1B241E; overflow: hidden;
    font-family: var(--mono);
    box-shadow: 0 14px 40px rgba(19, 26, 21, .28);
  }
  .case-topo-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 11px 16px; background: #212B24;
    border-bottom: 1px solid #00000040; font-size: 12px;
  }
  .case-topo-bar span { color: var(--marble-dark); opacity: .8; }
  .case-topo-bar em { font-style: normal; color: var(--gold); font-size: 11px; }
  .case-topo-body { padding: 16px 16px 18px; }
  .case-topo-body div { font-size: 13px; color: var(--marble); line-height: 1.5; padding: 5px 0; }
  .case-topo-body b { color: #fff; font-weight: 600; }

  /* AD — une ligne discrète */
  .case-note {
    border-top: 1px solid var(--stone);
    padding-top: 34px;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px 10px;
    color: var(--ink-muted); font-size: 14px; line-height: 1.6;
  }
  .case-note .case-index { margin-bottom: 0; }
  .case-note strong { font: 700 18px/1.2 var(--serif); color: var(--ink); }
  .case-note p { flex: 1; min-width: 260px; }
  .case-note .case-link { min-height: 0; white-space: nowrap; margin-left: auto; }

  @media (max-width: 760px) {
    .case-row,
    .case-row.rev { grid-template-columns: 1fr; gap: 24px; padding-block: 38px; }
    /* capture / topologie toujours au-dessus de la copy */
    .case-row > .case-copy { order: 2; }
    .case-row > .case-shot,
    .case-row > .case-topo { order: 1; }
    .case-note { padding-top: 30px; }
    .case-note .case-link { margin-left: 0; min-height: 40px; }
  }

  @media (max-width: 440px) {
    .case-title-row { align-items: flex-start; }
    h3 { font-size: 24px; }
    .case-facts div:not(:last-child)::after { margin: 0 6px 0 10px; }
    .case-facts dt { font-size: 18px; }
    .case-facts dd { font-size: 10.5px; }
  }
</style>
