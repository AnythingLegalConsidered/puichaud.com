---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects.js';

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const description = `${project.summary} ${project.outcome}`;
const gallery = project.gallery ?? [];
const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.name,
  creator: { '@type': 'Person', name: 'Ianis Puichaud', url: 'https://puichaud.com' },
  description,
  url: `https://puichaud.com/projets/${project.slug}/`,
  keywords: project.tags.join(', '),
};
---

<Base
  title={`${project.name} — étude de cas · Ianis Puichaud`}
  description={description}
  canonicalPath={`/projets/${project.slug}/`}
  image={project.image}
  schema={projectSchema}
>
  <a class="skip-link" href="#main">Aller au contenu</a>
  <Header />
  <main id="main" class="case-page">
    <header class="case-hero">
      <div class="wrap">
        <a class="back-link" href="/#projets">← Toutes les études de cas</a>
        <div class="case-kicker">{project.number} · {project.meta}</div>
        <div class="case-title-row">
          <h1>{project.name}</h1>
          <span>{project.status}</span>
        </div>
        <p class="case-lede">{project.summary}</p>
        <dl class="case-facts">
          {project.facts.map((fact) => (
            <div><dt>{fact.value}</dt><dd>{fact.label}</dd></div>
          ))}
        </dl>
        <div class="case-tags">
          {project.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </div>
    </header>

    {project.image && (
      <div class="wrap case-cover-wrap">
        <figure class="case-cover">
          <img src={project.image} alt={project.imageAlt} width="1280" height="577" decoding="async" />
          <figcaption>Capture réelle du projet — les informations sensibles ne sont pas publiées.</figcaption>
        </figure>
      </div>
    )}

    <div class="wrap case-body">
      <aside class="case-nav" aria-label="Sommaire de l’étude de cas">
        <span>Dans cette étude</span>
        <a href="#contexte">01 · Contexte</a>
        <a href="#realisation">02 · Réalisation</a>
        <a href="#resultats">03 · Résultats</a>
        <a href="#limites">04 · Limites</a>
      </aside>

      <article class="case-content">
        <section id="contexte">
          <div class="case-section-no">01</div>
          <h2>Le problème à résoudre</h2>
          <p>{project.challenge}</p>
          <blockquote>{project.outcome}</blockquote>
        </section>

        <section id="realisation">
          <div class="case-section-no">02</div>
          <h2>Ce que j’ai réellement fait</h2>
          <ul>
            {project.work.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section id="resultats">
          <div class="case-section-no">03</div>
          <h2>Preuves et résultats</h2>
          <ul class="results-list">
            {project.results.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        {gallery.length > 0 && (
          <div class="case-gallery">
            {gallery.map((image) => (
              <figure>
                <img src={image.src} alt={image.alt} width="1280" height="577" loading="lazy" decoding="async" />
                <figcaption>{image.alt}</figcaption>
              </figure>
            ))}
          </div>
        )}

        <section id="limites" class="limits-section">
          <div class="case-section-no">04</div>
          <h2>Ce que je ne prétends pas</h2>
          <ul>
            {project.limits.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <div class="case-cta">
          <div>
            <span>Pour aller plus loin</span>
            <h2>Je peux détailler les choix et les incidents en entretien.</h2>
          </div>
          <div>
            {project.external && <a class="btn primary" href={project.external.href} target="_blank" rel="noopener">{project.external.label} ↗</a>}
            <a class="btn ghost" href="/#contact">Me contacter</a>
          </div>
        </div>
      </article>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .case-page { background: var(--marble); }
  .case-hero {
    padding: 74px 0 62px;
    background: linear-gradient(160deg, var(--sidebar), var(--column));
    color: var(--marble);
  }
  .back-link {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    color: var(--marble-dark);
    font-size: 12px;
  }
  .case-kicker {
    margin-top: 28px;
    color: var(--gold);
    font: 500 11px/1.4 var(--mono);
    letter-spacing: .13em;
    text-transform: uppercase;
  }
  .case-title-row { display: flex; align-items: center; gap: 18px; margin-top: 10px; }
  .case-title-row h1 { font: 700 clamp(40px, 8vw, 72px)/1 var(--serif); }
  .case-title-row span {
    border: 1px solid rgba(201, 168, 76, .55);
    padding: 5px 9px;
    color: var(--gold);
    font: 500 10px/1 var(--mono);
    text-transform: uppercase;
  }
  .case-lede { max-width: 710px; margin-top: 22px; color: var(--marble-dark); font-size: 18px; }
  .case-facts { display: flex; margin-top: 34px; }
  .case-facts div { min-width: 145px; padding-right: 28px; }
  .case-facts div + div { padding-left: 28px; border-left: 1px solid rgba(250, 246, 240, .2); }
  .case-facts dt { font: 700 27px/1 var(--serif); color: #fff; }
  .case-facts dd { margin-top: 7px; color: var(--marble-dark); font: 500 9px/1.4 var(--mono); text-transform: uppercase; letter-spacing: .08em; }
  .case-tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 30px; }
  .case-tags span { border: 1px solid rgba(250, 246, 240, .25); padding: 4px 8px; color: var(--marble-dark); font: 400 10px/1 var(--mono); }

  .case-cover-wrap { position: relative; z-index: 2; }
  .case-cover { margin-top: -24px; border: 1px solid var(--stone); background: var(--column); box-shadow: 0 20px 60px rgba(30, 26, 21, .18); }
  .case-cover img { display: block; width: 100%; max-height: 460px; object-fit: cover; }
  figcaption { padding: 9px 12px; color: var(--ink-muted); background: var(--parchment); font: 400 9.5px/1.4 var(--mono); }

  .case-body { display: grid; grid-template-columns: 180px 1fr; gap: 56px; padding-top: 70px; }
  .case-nav { position: sticky; top: 100px; align-self: start; display: flex; flex-direction: column; }
  .case-nav span { margin-bottom: 12px; color: var(--ink); font: 700 10px/1.4 var(--mono); letter-spacing: .08em; text-transform: uppercase; }
  .case-nav a { min-height: 38px; display: flex; align-items: center; color: var(--ink-muted); font-size: 12px; border-bottom: 1px solid var(--marble-dark); }
  .case-nav a:hover { color: var(--bronze-dark); text-decoration: none; }

  .case-content { min-width: 0; }
  .case-content section { position: relative; padding: 0 0 58px 52px; }
  .case-content section + section { padding-top: 58px; border-top: 1px solid var(--stone); }
  .case-section-no { position: absolute; left: 0; top: 3px; color: var(--bronze-dark); font: 700 13px/1 var(--mono); }
  .case-content h2 { font: 700 25px/1.25 var(--serif); }
  .case-content p { margin-top: 18px; color: var(--ink-muted); }
  .case-content blockquote { margin-top: 26px; padding: 20px 24px; border-left: 3px solid var(--bronze); background: var(--parchment); color: var(--ink); font-size: 15px; }
  .case-content ul { margin-top: 20px; list-style: none; }
  .case-content li { position: relative; padding: 0 0 12px 24px; color: var(--ink-muted); }
  .case-content li::before { content: '—'; position: absolute; left: 0; color: var(--bronze); }
  .results-list li::before { content: '✓'; font-weight: 700; }
  .limits-section { border: 1px solid var(--stone) !important; background: var(--parchment); padding: 30px 30px 22px 82px !important; margin-bottom: 58px; }
  .limits-section .case-section-no { left: 30px; top: 35px; }

  .case-gallery { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; margin: 0 0 58px 52px; }
  .case-gallery figure { min-width: 0; border: 1px solid var(--stone); background: var(--column); }
  .case-gallery img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }

  .case-cta { display: flex; justify-content: space-between; gap: 30px; align-items: center; padding: 30px; background: var(--sidebar); color: var(--marble); }
  .case-cta span { color: var(--gold); font: 500 9px/1 var(--mono); text-transform: uppercase; letter-spacing: .1em; }
  .case-cta h2 { max-width: 430px; margin-top: 8px; color: var(--marble); font-size: 19px; }
  .case-cta > div:last-child { display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end; }
  .case-cta .btn.ghost { color: var(--marble); border-color: rgba(250, 246, 240, .3); }

  @media (max-width: 760px) {
    .case-hero { padding-top: 52px; }
    .case-title-row { align-items: flex-start; flex-direction: column; gap: 12px; }
    .case-facts { display: grid; grid-template-columns: repeat(3, 1fr); }
    .case-facts div { min-width: 0; padding-right: 12px; }
    .case-facts div + div { padding-left: 12px; }
    .case-facts dt { font-size: 21px; }
    .case-body { grid-template-columns: 1fr; gap: 0; padding-top: 48px; }
    .case-nav { display: none; }
    .case-content section { padding-left: 38px; }
    .case-gallery { grid-template-columns: 1fr; margin-left: 38px; }
    .limits-section { padding-left: 70px !important; }
    .case-cta { align-items: flex-start; flex-direction: column; }
    .case-cta > div:last-child { justify-content: flex-start; }
  }

  @media (max-width: 440px) {
    .case-lede { font-size: 16px; }
    .case-facts dd { font-size: 7.5px; }
    .case-content section { padding-left: 30px; }
    .case-gallery { margin-left: 30px; }
    .limits-section { padding: 24px 20px 16px 58px !important; }
    .limits-section .case-section-no { left: 20px; top: 29px; }
  }
</style>
